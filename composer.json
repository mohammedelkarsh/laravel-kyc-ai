{
    "name": "kyc-ai/laravel",
    "description": "Laravel KYC: extract identity documents with AI and verify with country-specific validators.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mohammedelkarsh/laravel-kyc-ai",
    "support": {
        "issues": "https://github.com/mohammedelkarsh/laravel-kyc-ai/issues",
        "source": "https://github.com/mohammedelkarsh/laravel-kyc-ai"
    },
    "keywords": [
        "laravel",
        "kyc",
        "identity",
        "saudi",
        "uae",
        "egypt",
        "ocr",
        "ai",
        "verification"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/bus": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "symfony/process": "^6.4|^7.0",
        "validators/sa": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.5",
        "validators/ae": "^1.0",
        "validators/eg": "^1.0"
    },
    "suggest": {
        "validators/ae": "UAE Emirates ID internal verification",
        "validators/eg": "Egyptian national ID internal verification",
        "filament/filament": "Admin UI for manual KYC review (^3.0)",
        "ext-fileinfo": "Better MIME detection for uploaded documents"
    },
    "autoload": {
        "psr-4": {
            "KycAi\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KycAi\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KycAi\\Laravel\\KycServiceProvider"
            ],
            "aliases": {
                "Kyc": "KycAi\\Laravel\\Facades\\Kyc"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:comprehensive": "phpunit --testdox"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
